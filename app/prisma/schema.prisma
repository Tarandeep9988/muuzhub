// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  provider  Provider  
  streams   Stream[]
  votes     Upvote[]
  rooms     Room[]    @relation("RoomAdmin")

  createdAt DateTime  @default(now())
}

model Room {
  id              String   @id @default(uuid())
  code            String   @unique
  adminId         String
  admin           User     @relation("RoomAdmin", fields: [adminId], references: [id])

  currentStreamId String?  @unique
  currentStream   Stream?  @relation("CurrentStream", fields: [currentStreamId], references: [id])

  streams         Stream[] @relation("RoomStreams")

  createdAt       DateTime @default(now())
  isActive        Boolean  @default(true)
}

model Stream {
  id            String     @id @default(uuid())

  roomId        String
  room          Room       @relation("RoomStreams", fields: [roomId], references: [id])

  userId        String
  user          User       @relation(fields: [userId], references: [id])

  type          StreamType
  url           String
  extractedId   String

  title         String     @default("")
  smallImageUrl String     @default("")
  bigImageUrl   String     @default("")

  active        Boolean    @default(true)
  played        Boolean    @default(false)

  upvotes       Upvote[]
  currentRoomId Room?      @relation("CurrentStream")

  createdAt     DateTime   @default(now())
}

model Upvote {
  id        String   @id @default(uuid())

  userId    String
  streamId  String

  user      User     @relation(fields: [userId], references: [id])
  stream    Stream   @relation(fields: [streamId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, streamId])
}

enum StreamType {
  Youtube
}

enum Provider {
  Google
}